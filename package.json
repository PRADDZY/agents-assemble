{
  "name": "agents-assemble",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:worker": "pnpm --filter @agents-assemble/mcp-worker dev",
    "dev:ui": "pnpm --filter @agents-assemble/proof-ui dev",
    "deploy:worker": "pnpm --filter @agents-assemble/mcp-worker deploy",
    "deploy:ui": "pnpm --filter @agents-assemble/proof-ui deploy",
    "secretcheck": "node scripts/check-no-secrets.mjs",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify": "pnpm typecheck && pnpm test && pnpm build && pnpm secretcheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  }
}

